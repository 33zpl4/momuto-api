<div id="colorModal" class="color-modal" style="display: none;">
<div id="colorModalOverlay" class="modal-overlay" onclick="closeColorModal()"></div>
<div class="color-modal-content">
<div class="color-modal-header">
<h3>Select Color</h3>
<button class="close-modal" onclick="closeColorModal()">&times;</button></div>
<div class="color-modal-body">
<div id="colorSwatches"></div>
</div>
