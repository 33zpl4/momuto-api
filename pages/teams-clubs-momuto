    }

    .carousel-header {
        text-align: left;
        margin-bottom: 2rem;
        padding-left: 40px; /* Match container padding */
        max-width: 1400px;
        margin: 0 auto 2rem auto;
    }

    .carousel-title {
        font-size: 1.5rem;
        font-weight: 800;
        color: #111;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        display: flex;
        align-items: center;
        gap: 1rem;
    }
    
    /* Arrow to indicate scrolling */
    .carousel-title::after {
        content: "→";
        font-size: 1.5rem;
        font-weight: 400;
    }

    .teams-carousel {
        display: flex;
        overflow-x: auto;
        gap: 1.5rem;
        padding: 1rem 40px 3rem 40px; /* Padding matches container */
        scroll-behavior: smooth;
        -ms-overflow-style: none;
        scrollbar-width: none;
    }
    
    .teams-carousel::-webkit-scrollbar { display: none; }

    .team-card {
        flex: 0 0 28vw; /* Shows 3 full + part of next on desktop */
        min-width: 320px;
        max-width: 450px;
        background: transparent;
        border: none;
        cursor: pointer;
        position: relative;
    }

    .team-image {
        width: 100%;
        height: 420px;
        background: #ffffff;
        display: flex;
        align-items: center;
        justify-content: center;
        position: relative;
        overflow: hidden;
        margin-bottom: 1rem;
        box-shadow: 0 4px 6px rgba(0,0,0,0.02);
        transition: transform 0.4s ease;
    }

    .team-image img {
        width: 90%;
        height: 90%;
        object-fit: contain;
        transition: transform 0.6s cubic-bezier(0.165, 0.84, 0.44, 1);
        mix-blend-mode: multiply;
    }

    /* Hover Effects */
    .team-card:hover .team-image { transform: translateY(-5px); }
    .team-card:hover .team-image img { transform: scale(1.1); }

    .team-info { padding: 0; text-align: left; }

    .team-name {
        font-weight: 800;
        color: #111;
        font-size: 1.1rem;
        text-transform: uppercase;
        letter-spacing: -0.02em;
        margin-bottom: 0.25rem;
    }

    .team-location {
        font-size: 0.85rem;
        color: #71717a;
        font-weight: 500;
        margin-bottom: 0.5rem;
    }

    /* FIX 1: LEAGUE TAG STYLING */
    .team-league {
        background: #111; /* Black tag */
        color: #fff;
        padding: 0.25rem 0.5rem;
        font-size: 0.65rem;
        font-weight: 700;
        letter-spacing: 0.05em;
        text-transform: uppercase;
        display: inline-block;
        line-height: 1;
    }

    /* --- 3. GALLERY --- */
    .action-gallery-section {
        background: #fafafa; /* Very subtle off-white/bone */
        color: #111;
        padding: 6rem 0;
        border-top: 1px solid #eaeaea;
    }

    .gallery-title {
        font-size: 2rem;
        font-weight: 800;
        color: #111;
        margin-bottom: 0.5rem;
        text-align: center;
        text-transform: uppercase;
        letter-spacing: -0.03em;
    }

    .gallery-subtitle {
        color: #71717a;
        font-size: 1.1rem;
        text-align: center;
        margin-bottom: 3rem;
    }

    .filter-btn {
        background: transparent;
        color: #71717a;
        border: 1px solid #d4d4d8;
        border-radius: 0;
        text-transform: uppercase;
        font-size: 0.8rem;
        letter-spacing: 0.1em;
        padding: 0.8rem 1.5rem;
        font-weight: 600;
        margin: 0 5px;
    }

    .filter-btn.active, .filter-btn:hover {
        background: #111;
        color: #fff;
        border-color: #111;
    }

    .masonry-gallery {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 4px;
    }

    .action-photo {
        position: relative;
        overflow: hidden;
        cursor: pointer;
    }
    .action-photo img {
        width: 100%;
        height: auto;
        display: block;
        transition: transform 0.5s ease;
    }

    /* FIX 2: STRONGER GRADIENT FOR READABILITY ON DARK PHOTOS */
    .action-overlay {
        position: absolute;
        bottom: 0; left: 0; right: 0;
        /* Stronger gradient that goes to near-black at the bottom */
        background: linear-gradient(to bottom, transparent 0%, rgba(0,0,0,0.5) 40%, rgba(0,0,0,0.95) 100%);
        color: white;
        padding: 2rem 1.5rem 1.5rem 1.5rem; /* More top padding for gradient breath */
        opacity: 0;
        transition: all 0.3s ease;
        transform: translateY(10px); /* Subtle slide up effect */
    }

    .action-overlay .team-name {
        font-weight: 800;
        font-size: 1rem;
        text-transform: uppercase;
        letter-spacing: -0.02em;
        color: #fff;
        /* Subtle text shadow for absolute worst-case scenarios */
        text-shadow: 0 2px 4px rgba(0,0,0,0.3);
    }

    .action-photo:hover img { transform: scale(1.05); }
    .action-photo:hover .action-overlay { opacity: 1; transform: translateY(0); }


    /* --- 4. UGC & FOOTER --- */
    .ugc-cta-section {
        background: white;
        border: 1px solid #eaeaea;
        padding: 4rem;
        margin-top: 4rem;
        text-align: center;
    }

