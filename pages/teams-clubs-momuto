        font-weight: 700;
        display: inline-block;
        text-decoration: none;
        transition: all 0.3s ease;
    }
    .btn-secondary:hover { background: #111; color: white; }

    .footer-cta-wrapper {
        background: #111;
        padding: 8rem 0;
        margin-top: 0;
    }
    .final-cta-section { text-align: center; }
    .cta-title { color: #fff; font-size: 2.5rem; font-weight: 800; text-transform: uppercase; margin-bottom: 1rem; }
    .cta-description { color: #a1a1aa; font-size: 1.1rem; margin-bottom: 3rem; }
    
    .btn-primary {
        background: #fff;
        color: #111;
        padding: 20px 50px;
        border: none;
        text-transform: uppercase;
        letter-spacing: 0.15em;
        font-size: 1rem;
        font-weight: 800;
        cursor: pointer;
        display: inline-block;
        text-decoration: none;
        transition: transform 0.2s;
    }
    .btn-primary:hover { transform: scale(1.05); }

    /* --- 5. LIGHTBOX --- */
    .lightbox {
        display: none;
        position: fixed;
        z-index: 9999;
        left: 0; top: 0;
        width: 100%; height: 100%;
        background-color: rgba(255,255,255,0.98); /* cleaner white */
        animation: fadeIn 0.3s ease;
        justify-content: center;
        align-items: center;
    }
    .lightbox.active { display: flex; }
    
    .lightbox-content {
        max-width: 900px;
        max-height: 90vh;
        position: relative;
        box-shadow: 0 30px 60px rgba(0,0,0,0.1);
        background: transparent;
    }
    
    .lightbox-image {
        max-width: 100%;
        max-height: 85vh;
        display: block;
        /* Ensure blended images look right in lightbox too */
        mix-blend-mode: multiply; 
    }
    
    .lightbox-close {
        position: absolute;
        top: -40px; right: 0;
        font-size: 30px;
        color: #111;
        cursor: pointer;
        z-index: 100;
    }

    @keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }

    /* SR-ONLY: visible to crawlers & screen readers, hidden visually */
    .sr-only {
        position: absolute;
        width: 1px;
        height: 1px;
        padding: 0;
        margin: -1px;
        overflow: hidden;
        clip: rect(0, 0, 0, 0);
        white-space: nowrap;
        border: 0;
    }

    .action-photo figure { margin: 0; }
    .action-photo figcaption { position: absolute; bottom: 0; left: 0; right: 0; pointer-events: none; }
    .action-photo figcaption .photo-meta { position: absolute; width: 1px; height: 1px; padding: 0; margin: -1px; overflow: hidden; clip: rect(0,0,0,0); white-space: nowrap; border: 0; }

    /* RESPONSIVE */
    @media (max-width: 768px) {
        .main-title { font-size: 2.5rem; }
        .portfolio-stats { gap: 2rem; flex-wrap: wrap; }
        .team-card { flex: 0 0 75vw; } /* Mobile: show 1 card + peek of next */
        .team-image { height: 350px; }
        .masonry-gallery { grid-template-columns: 1fr; }
        .carousel-header { padding-left: 20px; }
        .teams-carousel { padding: 1rem 20px 3rem 20px; }
        .container { padding: 0 20px; }
    }
